#!/usr/bin/env bash
set -euo pipefail

go_version="1.25.12"
case "$(uname -m)" in
  x86_64)
    go_arch="amd64"
    go_sha256="234828b7a89e0e303d2556310ee549fbcf253d28de937bac3da13d6294262ac1"
    ;;
  aarch64|arm64)
    go_arch="arm64"
    go_sha256="8b5884aef89600aef5b0b051fb971f11f49bb996521e911f30f02a66884f7bd2"
    ;;
  *) echo "Unsupported architecture: $(uname -m)" >&2; exit 1 ;;
esac

if ! command -v go >/dev/null 2>&1 || [[ "$(go env GOVERSION 2>/dev/null || true)" != "go${go_version}" ]]; then
  archive="go${go_version}.linux-${go_arch}.tar.gz"
  tmp_dir="$(mktemp -d)"
  trap 'rm -rf "$tmp_dir"' EXIT

  echo "Installing Go ${go_version}..."
  curl --fail --location --silent --show-error "https://go.dev/dl/${archive}" -o "${tmp_dir}/${archive}"
  printf '%s  %s\n' "$go_sha256" "${tmp_dir}/${archive}" | sha256sum --check --status
  rm -rf /usr/local/go
  tar -C /usr/local -xzf "${tmp_dir}/${archive}"
fi

ln -sf /usr/local/go/bin/go /usr/local/bin/go
ln -sf /usr/local/go/bin/gofmt /usr/local/bin/gofmt

echo "Downloading Go modules..."
go mod download

if ! command -v govulncheck >/dev/null 2>&1; then
  echo "Installing govulncheck..."
  GOBIN=/usr/local/bin go install golang.org/x/vuln/cmd/govulncheck@v1.6.0
fi

if ! command -v golangci-lint >/dev/null 2>&1; then
  echo "Installing golangci-lint..."
  GOBIN=/usr/local/bin go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.8.0
fi
